{% doc %}
  @prompt
    Add custom CSS to make the header section overlay/float on top of the slideshow/banner section. The header should be positioned absolutely or with negative margin so it sits on top of the first section (slideshow), making the slideshow image visible behind the header. The header background should be transparent or semi-transparent so the slideshow shows through. This should not affect other pages where there is no slideshow.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-header-overlay-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  {% if block.settings.enable_overlay %}
    .shopify-section-group-header-group {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      z-index: {{ block.settings.header_z_index }};
      background-color: {{ block.settings.header_bg_color }};
    }

    .shopify-section-group-header-group + .shopify-section {
      margin-top: 0;
    }

    {% if block.settings.transparent_header %}
      .shopify-section-group-header-group {
        background-color: transparent;
      }

      .shopify-section-group-header-group .header {
        background-color: {{ block.settings.header_bg_color }};
      }
    {% endif %}

    @media screen and (max-width: 749px) {
      {% if block.settings.enable_mobile_overlay %}
        .shopify-section-group-header-group {
          position: absolute;
        }
      {% else %}
        .shopify-section-group-header-group {
          position: relative;
        }

        .shopify-section-group-header-group + .shopify-section {
          margin-top: 0;
        }
      {% endif %}
    }
  {% endif %}
{% endstyle %}

<div class="ai-header-overlay-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_message %}
    <div style="
      padding: 12px;
      text-align: center;
      background-color: {{ block.settings.message_bg_color }};
      color: {{ block.settings.message_text_color }};
      font-size: 14px;
    ">
      {{ block.settings.message_text }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Header overlay CSS",
  "settings": [
    {
      "type": "header",
      "content": "Overlay settings"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Enable header overlay",
      "default": true,
      "info": "Makes the header float on top of the first section"
    },
    {
      "type": "checkbox",
      "id": "transparent_header",
      "label": "Transparent header background",
      "default": true,
      "info": "Makes the header background transparent to show the slideshow behind it"
    },
    {
      "type": "color",
      "id": "header_bg_color",
      "label": "Header background color",
      "default": "rgba(255, 255, 255, 0.9)",
      "info": "Used when transparent header is disabled or for the header container"
    },
    {
      "type": "range",
      "id": "header_z_index",
      "label": "Header layer position",
      "min": 10,
      "max": 100,
      "step": 10,
      "default": 50,
      "info": "Controls how high the header sits above other content"
    },
    {
      "type": "checkbox",
      "id": "enable_mobile_overlay",
      "label": "Enable overlay on mobile",
      "default": false,
      "info": "Apply the overlay effect on mobile devices"
    },
    {
      "type": "header",
      "content": "Optional message"
    },
    {
      "type": "checkbox",
      "id": "show_message",
      "label": "Show informational message",
      "default": false,
      "info": "Display a message to explain the overlay is active"
    },
    {
      "type": "richtext",
      "id": "message_text",
      "label": "Message text",
      "default": "<p>Header overlay is active on this page</p>"
    },
    {
      "type": "color",
      "id": "message_bg_color",
      "label": "Message background",
      "default": "#f0f0f0"
    },
    {
      "type": "color",
      "id": "message_text_color",
      "label": "Message text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Header overlay CSS"
    }
  ]
}
{% endschema %}
