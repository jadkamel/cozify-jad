    "custom_liquid_EieYPh": {
      "type": "custom-liquid",
      "name": "t:sections.refactor_words.custom_code.name",
      "settings": {
        "heading": "",
        "subheading": "",
        "section_heading_layout": "section-heading--left",
        "custom_liquid": "{% comment %}\n=====================================================\nNUTREA LUXURY ACCORDION\nFULL COPY-PASTE VERSION\n=====================================================\n\n01 — Benefits\n02 — How to use\n03 — Nutrition facts\n04 — Disclaimer\n\nAlso removes Shopify blank space above the section.\n=====================================================\n{% endcomment %}\n\n\n{% comment %}\n=====================================================\nEDIT COLORS AND SIZES HERE\n=====================================================\n{% endcomment %}\n\n{% assign accordion_background = '#FFFDFC' %}\n{% assign text_color = '#2B211C' %}\n{% assign muted_text_color = '#6D5B50' %}\n{% assign accent_color = '#B08968' %}\n{% assign line_color = '#E7DDD4' %}\n\n{% assign desktop_title_size = 14 %}\n{% assign mobile_title_size = 13 %}\n\n{% assign desktop_body_size = 14 %}\n{% assign mobile_body_size = 13 %}\n\n{% assign row_padding = 17 %}\n{% assign mobile_row_padding = 15 %}\n\n\n\n<div\n  class=\"nutrea-luxe-accordion\"\n  style=\"\n    --nla-background: {{ accordion_background }};\n    --nla-text: {{ text_color }};\n    --nla-muted: {{ muted_text_color }};\n    --nla-accent: {{ accent_color }};\n    --nla-line: {{ line_color }};\n\n    --nla-title-size: {{ desktop_title_size }}px;\n    --nla-mobile-title-size: {{ mobile_title_size }}px;\n\n    --nla-body-size: {{ desktop_body_size }}px;\n    --nla-mobile-body-size: {{ mobile_body_size }}px;\n\n    --nla-row-padding: {{ row_padding }}px;\n    --nla-mobile-row-padding: {{ mobile_row_padding }}px;\n  \"\n>\n\n\n\n  {% comment %}\n  =====================================================\n  01 — BENEFITS\n  =====================================================\n  {% endcomment %}\n\n  <details class=\"nutrea-luxe-accordion__item\">\n\n    <summary class=\"nutrea-luxe-accordion__summary\">\n\n      <span class=\"nutrea-luxe-accordion__number\">\n        01\n      </span>\n\n      <span class=\"nutrea-luxe-accordion__title\">\n        Benefits\n      </span>\n\n      <span\n        class=\"nutrea-luxe-accordion__plus\"\n        aria-hidden=\"true\"\n      ></span>\n\n    </summary>\n\n\n    <div class=\"nutrea-luxe-accordion__content\">\n\n      <div class=\"nutrea-benefit-list\">\n\n\n        <div class=\"nutrea-benefit-list__item\">\n\n          <span class=\"nutrea-benefit-list__symbol\">\n            ✦\n          </span>\n\n          <div>\n            <strong>\n              Skin elasticity & glow\n            </strong>\n\n            <span>\n              Daily collagen support for skin appearance,\n              hair, and nails.\n            </span>\n          </div>\n\n        </div>\n\n\n        <div class=\"nutrea-benefit-list__item\">\n\n          <span class=\"nutrea-benefit-list__symbol\">\n            ◌\n          </span>\n\n          <div>\n            <strong>\n              Daily hydration\n            </strong>\n\n            <span>\n              Electrolytes help support fluid and mineral\n              balance.\n            </span>\n          </div>\n\n        </div>\n\n\n        <div class=\"nutrea-benefit-list__item\">\n\n          <span class=\"nutrea-benefit-list__symbol\">\n            ◇\n          </span>\n\n          <div>\n            <strong>\n              Joint support\n            </strong>\n\n            <span>\n              Supports everyday joint comfort and mobility.\n            </span>\n          </div>\n\n        </div>\n\n\n        <div class=\"nutrea-benefit-list__item\">\n\n          <span class=\"nutrea-benefit-list__symbol\">\n            ↗\n          </span>\n\n          <div>\n            <strong>\n              Recovery support\n            </strong>\n\n            <span>\n              Protein and electrolytes support your daily\n              recovery routine.\n            </span>\n          </div>\n\n        </div>\n\n\n        <div class=\"nutrea-benefit-list__item\">\n\n          <span class=\"nutrea-benefit-list__symbol\">\n            ✧\n          </span>\n\n          <div>\n            <strong>\n              Hair & nail support\n            </strong>\n\n            <span>\n              Consistent collagen intake supports strength\n              from within.\n            </span>\n          </div>\n\n        </div>\n\n\n      </div>\n\n    </div>\n\n  </details>\n\n\n\n  {% comment %}\n  =====================================================\n  02 — HOW TO USE\n  =====================================================\n  {% endcomment %}\n\n  <details class=\"nutrea-luxe-accordion__item\">\n\n    <summary class=\"nutrea-luxe-accordion__summary\">\n\n      <span class=\"nutrea-luxe-accordion__number\">\n        02\n      </span>\n\n      <span class=\"nutrea-luxe-accordion__title\">\n        How to use\n      </span>\n\n      <span\n        class=\"nutrea-luxe-accordion__plus\"\n        aria-hidden=\"true\"\n      ></span>\n\n    </summary>\n\n\n    <div class=\"nutrea-luxe-accordion__content\">\n\n      <div class=\"nutrea-use-steps\">\n\n\n        <div class=\"nutrea-use-step\">\n\n          <span class=\"nutrea-use-step__number\">\n            1\n          </span>\n\n          <div>\n            <strong>\n              Measure\n            </strong>\n\n            <span>\n              Add one 8 g serving of Nutrea.\n            </span>\n          </div>\n\n        </div>\n\n\n        <div class=\"nutrea-use-step\">\n\n          <span class=\"nutrea-use-step__number\">\n            2\n          </span>\n\n          <div>\n            <strong>\n              Mix\n            </strong>\n\n            <span>\n              Add to 200–250 ml of water, then stir or shake\n              until well combined.\n            </span>\n          </div>\n\n        </div>\n\n\n        <div class=\"nutrea-use-step\">\n\n          <span class=\"nutrea-use-step__number\">\n            3\n          </span>\n\n          <div>\n            <strong>\n              Make it daily\n            </strong>\n\n            <span>\n              Enjoy once daily. Nutrea can also be added to\n              smoothies.\n            </span>\n          </div>\n\n        </div>\n\n\n      </div>\n\n\n      <p class=\"nutrea-luxe-accordion__note\">\n\n        Any time of day works. The most important part is\n        consistency.\n\n      </p>\n\n    </div>\n\n  </details>\n\n\n\n  {% comment %}\n  =====================================================\n  03 — NUTRITION FACTS\n  =====================================================\n  {% endcomment %}\n\n  <details class=\"nutrea-luxe-accordion__item\">\n\n    <summary class=\"nutrea-luxe-accordion__summary\">\n\n      <span class=\"nutrea-luxe-accordion__number\">\n        03\n      </span>\n\n      <span class=\"nutrea-luxe-accordion__title\">\n        Nutrition facts\n      </span>\n\n      <span\n        class=\"nutrea-luxe-accordion__plus\"\n        aria-hidden=\"true\"\n      ></span>\n\n    </summary>\n\n\n    <div class=\"nutrea-luxe-accordion__content\">\n\n      <div class=\"nutrea-nutrition\">\n\n\n        <div class=\"nutrea-nutrition__top\">\n\n          <span>\n            Per serving\n          </span>\n\n          <strong>\n            8 g\n          </strong>\n\n        </div>\n\n\n        <div class=\"nutrea-nutrition__row\">\n\n          <span>\n            Calories\n          </span>\n\n          <strong>\n            24 kcal\n          </strong>\n\n        </div>\n\n\n        <div class=\"nutrea-nutrition__row\">\n\n          <span>\n            Protein\n          </span>\n\n          <strong>\n            6 g\n          </strong>\n\n        </div>\n\n\n        <div class=\"nutrea-nutrition__row\">\n\n          <span>\n            Vitamin C\n          </span>\n\n          <strong>\n            150 mg\n          </strong>\n\n        </div>\n\n\n\n        <div class=\"nutrea-nutrition__section-title\">\n\n          <span>\n            Electrolyte sources\n          </span>\n\n        </div>\n\n\n\n        <div class=\"nutrea-nutrition__row\">\n\n          <span>\n\n            Sea Salt\n\n            <small>\n              Sodium source\n            </small>\n\n          </span>\n\n          <strong>\n            180 mg\n          </strong>\n\n        </div>\n\n\n        <div class=\"nutrea-nutrition__row\">\n\n          <span>\n\n            Potassium Citrate\n\n            <small>\n              Potassium source\n            </small>\n\n          </span>\n\n          <strong>\n            200 mg\n          </strong>\n\n        </div>\n\n\n        <div class=\"nutrea-nutrition__row\">\n\n          <span>\n\n            Magnesium Citrate\n\n            <small>\n              Magnesium source\n            </small>\n\n          </span>\n\n          <strong>\n            150 mg\n          </strong>\n\n        </div>\n\n\n\n        <div class=\"nutrea-nutrition__footer-row\">\n\n          <span>\n            Servings per container\n          </span>\n\n          <strong>\n            25\n          </strong>\n\n        </div>\n\n\n      </div>\n\n    </div>\n\n  </details>\n\n\n\n  {% comment %}\n  =====================================================\n  04 — DISCLAIMER\n  =====================================================\n  {% endcomment %}\n\n  <details class=\"nutrea-luxe-accordion__item\">\n\n    <summary class=\"nutrea-luxe-accordion__summary\">\n\n      <span class=\"nutrea-luxe-accordion__number\">\n        04\n      </span>\n\n      <span class=\"nutrea-luxe-accordion__title\">\n        Disclaimer\n      </span>\n\n      <span\n        class=\"nutrea-luxe-accordion__plus\"\n        aria-hidden=\"true\"\n      ></span>\n\n    </summary>\n\n\n    <div class=\"nutrea-luxe-accordion__content\">\n\n      <div class=\"nutrea-disclaimer\">\n\n        <p>\n          Individual experiences and results may vary.\n          Use only as directed.\n        </p>\n\n        <p>\n          Pregnant women should consult their doctor before use.\n        </p>\n\n        <p>\n          Keep out of reach of children and store in a cool,\n          dry place.\n        </p>\n\n      </div>\n\n    </div>\n\n  </details>\n\n\n</div>\n\n\n\n<style>\n\n  /* =====================================================\n     REMOVE SHOPIFY BLANK SPACE ABOVE THIS CUSTOM LIQUID\n  ===================================================== */\n\n  .shopify-section:has(.nutrea-luxe-accordion) {\n    margin-top: 40px !important;\n\n    padding-top: 0 !important;\n\n    --section-vertical-spacing: 0px !important;\n\n    --section-spacing-block-start: 0px !important;\n\n    --section-outer-spacing-block: 0px !important;\n  }\n\n\n  .shopify-section:has(.nutrea-luxe-accordion) > div {\n    margin-top: 0 !important;\n\n    padding-top: 0 !important;\n  }\n\n\n  .shopify-section:has(.nutrea-luxe-accordion)\n  .section-spacing,\n\n  .shopify-section:has(.nutrea-luxe-accordion)\n  .section-spacing--tight,\n\n  .shopify-section:has(.nutrea-luxe-accordion)\n  .section-stack,\n\n  .shopify-section:has(.nutrea-luxe-accordion)\n  .custom-liquid,\n\n  .shopify-section:has(.nutrea-luxe-accordion)\n  .container {\n\n    margin-top: 0 !important;\n\n    padding-top: 0 !important;\n  }\n\n\n\n  /* =====================================================\n     MOVE THE ACCORDION SLIGHTLY UP\n     \n     CHANGE -12px BELOW:\n     \n     0px = no pull upward\n     -5px = tiny\n     -12px = recommended\n     -20px = stronger\n     -30px = very close\n  ===================================================== */\n\n  .nutrea-luxe-accordion {\n    margin-top: -12px !important;\n  }\n\n\n\n  /* =====================================================\n     MAIN WRAPPER\n  ===================================================== */\n\n  .nutrea-luxe-accordion {\n    width: 100%;\n\n    background: var(--nla-background);\n\n    color: var(--nla-text);\n\n    border-top:\n      1px solid\n      var(--nla-line);\n  }\n\n\n\n  /* =====================================================\n     EACH ACCORDION\n  ===================================================== */\n\n  .nutrea-luxe-accordion__item {\n    margin: 0;\n\n    padding: 0;\n\n    border: 0;\n\n    border-bottom:\n      1px solid\n      var(--nla-line);\n\n    background: transparent;\n  }\n\n\n  .nutrea-luxe-accordion__item[open] {\n    background: transparent;\n  }\n\n\n\n  /* =====================================================\n     SUMMARY / TITLE ROW\n  ===================================================== */\n\n  .nutrea-luxe-accordion__summary {\n    display: grid;\n\n    grid-template-columns:\n      28px\n      minmax(0, 1fr)\n      22px;\n\n    align-items: center;\n\n    gap: 12px;\n\n    min-height: 52px;\n\n    padding:\n      var(--nla-row-padding)\n      4px;\n\n    cursor: pointer;\n\n    list-style: none;\n\n    user-select: none;\n  }\n\n\n  .nutrea-luxe-accordion__summary::-webkit-details-marker {\n    display: none;\n  }\n\n\n  .nutrea-luxe-accordion__summary::marker {\n    display: none;\n  }\n\n\n\n  /* =====================================================\n     SMALL NUMBER\n  ===================================================== */\n\n  .nutrea-luxe-accordion__number {\n    color: var(--nla-accent);\n\n    font-size: 9px;\n\n    font-weight: 700;\n\n    line-height: 1;\n\n    letter-spacing: 1px;\n\n    opacity: 0.68;\n  }\n\n\n\n  /* =====================================================\n     TITLE\n  ===================================================== */\n\n  .nutrea-luxe-accordion__title {\n    color: var(--nla-text);\n\n    font-family: inherit;\n\n    font-size: var(--nla-title-size);\n\n    font-weight: 500;\n\n    line-height: 1.2;\n\n    letter-spacing: 0.2px;\n  }\n\n\n\n  /* =====================================================\n     PLUS / MINUS\n  ===================================================== */\n\n  .nutrea-luxe-accordion__plus {\n    position: relative;\n\n    display: block;\n\n    width: 16px;\n\n    height: 16px;\n\n    justify-self: end;\n  }\n\n\n  .nutrea-luxe-accordion__plus::before,\n  .nutrea-luxe-accordion__plus::after {\n    content: \"\";\n\n    position: absolute;\n\n    top: 50%;\n\n    left: 50%;\n\n    width: 12px;\n\n    height: 1px;\n\n    background: var(--nla-accent);\n\n    transform:\n      translate(-50%, -50%);\n\n    transition:\n      transform 0.25s ease,\n      opacity 0.25s ease;\n  }\n\n\n  .nutrea-luxe-accordion__plus::after {\n    transform:\n      translate(-50%, -50%)\n      rotate(90deg);\n  }\n\n\n  .nutrea-luxe-accordion__item[open]\n  .nutrea-luxe-accordion__plus::after {\n    opacity: 0;\n\n    transform:\n      translate(-50%, -50%)\n      rotate(0deg);\n  }\n\n\n\n  /* =====================================================\n     CONTENT\n  ===================================================== */\n\n  .nutrea-luxe-accordion__content {\n    padding:\n      0\n      4px\n      20px\n      40px;\n\n    color: var(--nla-muted);\n\n    font-size: var(--nla-body-size);\n\n    line-height: 1.55;\n  }\n\n\n\n  /* =====================================================\n     BENEFITS\n  ===================================================== */\n\n  .nutrea-benefit-list {\n    display: flex;\n\n    flex-direction: column;\n\n    gap: 13px;\n  }\n\n\n  .nutrea-benefit-list__item {\n    display: grid;\n\n    grid-template-columns:\n      24px\n      minmax(0, 1fr);\n\n    gap: 10px;\n\n    align-items: start;\n  }\n\n\n  .nutrea-benefit-list__symbol {\n    display: inline-flex;\n\n    align-items: center;\n\n    justify-content: center;\n\n    width: 24px;\n\n    height: 24px;\n\n    border-radius: 999px;\n\n    background: #F6EEE7;\n\n    color: var(--nla-accent);\n\n    font-size: 12px;\n\n    line-height: 1;\n  }\n\n\n  .nutrea-benefit-list__item div {\n    display: flex;\n\n    flex-direction: column;\n\n    gap: 2px;\n  }\n\n\n  .nutrea-benefit-list__item strong {\n    color: var(--nla-text);\n\n    font-size: inherit;\n\n    font-weight: 600;\n  }\n\n\n\n  /* =====================================================\n     HOW TO USE\n  ===================================================== */\n\n  .nutrea-use-steps {\n    display: flex;\n\n    flex-direction: column;\n\n    gap: 14px;\n  }\n\n\n  .nutrea-use-step {\n    display: grid;\n\n    grid-template-columns:\n      27px\n      minmax(0, 1fr);\n\n    gap: 10px;\n\n    align-items: start;\n  }\n\n\n  .nutrea-use-step__number {\n    display: inline-flex;\n\n    align-items: center;\n\n    justify-content: center;\n\n    width: 25px;\n\n    height: 25px;\n\n    border-radius: 999px;\n\n    background: #F6EEE7;\n\n    color: var(--nla-accent);\n\n    font-size: 10px;\n\n    font-weight: 700;\n  }\n\n\n  .nutrea-use-step div {\n    display: flex;\n\n    flex-direction: column;\n\n    gap: 2px;\n  }\n\n\n  .nutrea-use-step strong {\n    color: var(--nla-text);\n\n    font-weight: 600;\n  }\n\n\n  .nutrea-luxe-accordion__note {\n    margin:\n      16px\n      0\n      0;\n\n    padding-left: 37px;\n\n    color: var(--nla-accent);\n\n    font-size:\n      calc(\n        var(--nla-body-size) - 1px\n      );\n\n    font-style: italic;\n  }\n\n\n\n  /* =====================================================\n     NUTRITION FACTS\n  ===================================================== */\n\n  .nutrea-nutrition {\n    width: 100%;\n\n    max-width: 520px;\n  }\n\n\n  .nutrea-nutrition__top,\n  .nutrea-nutrition__row,\n  .nutrea-nutrition__footer-row {\n    display: flex;\n\n    align-items: center;\n\n    justify-content: space-between;\n\n    gap: 24px;\n  }\n\n\n  .nutrea-nutrition__top {\n    padding-bottom: 9px;\n\n    margin-bottom: 4px;\n\n    color: var(--nla-text);\n\n    border-bottom:\n      1px solid\n      var(--nla-accent);\n\n    font-size:\n      calc(\n        var(--nla-body-size) - 1px\n      );\n\n    text-transform: uppercase;\n\n    letter-spacing: 0.8px;\n  }\n\n\n  .nutrea-nutrition__row {\n    padding:\n      9px\n      0;\n\n    border-bottom:\n      1px solid\n      var(--nla-line);\n  }\n\n\n  .nutrea-nutrition__row > span {\n    display: flex;\n\n    flex-direction: column;\n\n    gap: 1px;\n  }\n\n\n  .nutrea-nutrition__row small {\n    color: var(--nla-accent);\n\n    font-size:\n      calc(\n        var(--nla-body-size) - 3px\n      );\n\n    font-weight: 500;\n\n    line-height: 1.2;\n\n    letter-spacing: 0.3px;\n  }\n\n\n  .nutrea-nutrition__section-title {\n    padding:\n      17px\n      0\n      6px;\n\n    color: var(--nla-accent);\n\n    font-size:\n      calc(\n        var(--nla-body-size) - 2px\n      );\n\n    font-weight: 700;\n\n    line-height: 1.2;\n\n    letter-spacing: 1px;\n\n    text-transform: uppercase;\n  }\n\n\n  .nutrea-nutrition__footer-row {\n    margin-top: 8px;\n\n    padding:\n      12px\n      0\n      0;\n\n    color: var(--nla-text);\n\n    border-top:\n      1px solid\n      var(--nla-accent);\n  }\n\n\n  .nutrea-nutrition strong {\n    color: var(--nla-text);\n\n    font-weight: 600;\n\n    white-space: nowrap;\n  }\n\n\n\n  /* =====================================================\n     DISCLAIMER\n  ===================================================== */\n\n  .nutrea-disclaimer {\n    max-width: 650px;\n  }\n\n\n  .nutrea-disclaimer p {\n    margin:\n      0\n      0\n      9px;\n  }\n\n\n  .nutrea-disclaimer p:last-child {\n    margin-bottom: 0;\n  }\n\n\n\n  /* =====================================================\n     MOBILE\n  ===================================================== */\n\n  @media screen and (max-width: 749px) {\n\n    .nutrea-luxe-accordion {\n      margin-top: -10px !important;\n    }\n\n\n    .nutrea-luxe-accordion__summary {\n      grid-template-columns:\n        24px\n        minmax(0, 1fr)\n        20px;\n\n      gap: 9px;\n\n      min-height: 48px;\n\n      padding:\n        var(--nla-mobile-row-padding)\n        2px;\n    }\n\n\n    .nutrea-luxe-accordion__title {\n      font-size:\n        var(--nla-mobile-title-size);\n    }\n\n\n    .nutrea-luxe-accordion__content {\n      padding:\n        0\n        2px\n        18px\n        33px;\n\n      font-size:\n        var(--nla-mobile-body-size);\n    }\n\n\n    .nutrea-luxe-accordion__note {\n      padding-left: 35px;\n\n      font-size:\n        calc(\n          var(--nla-mobile-body-size) - 1px\n        );\n    }\n\n\n    .nutrea-nutrition__row,\n    .nutrea-nutrition__footer-row {\n      gap: 12px;\n    }\n\n\n    .nutrea-nutrition__row small {\n      font-size:\n        calc(\n          var(--nla-mobile-body-size) - 3px\n        );\n    }\n\n  }\n\n</style>",
