le>\n\n  /* =====================================================\n     REMOVE ALL WHITE SPACE AROUND THE SCROLLING BAR\n  ===================================================== */\n\n\n  .shopify-section:has(.nutrea-marquee),\n  .nutrea-marquee-section {\n    margin-top: 0 !important;\n    margin-bottom: 0 !important;\n\n    padding-top: 0 !important;\n    padding-bottom: 0 !important;\n\n    --section-vertical-spacing: 0px !important;\n    --section-spacing-block-start: 0px !important;\n    --section-spacing-block-end: 0px !important;\n  }\n\n\n  .shopify-section:has(.nutrea-marquee) .section-spacing,\n  .shopify-section:has(.nutrea-marquee) .section-spacing--tight,\n  .shopify-section:has(.nutrea-marquee) .section-stack,\n  .shopify-section:has(.nutrea-marquee) .custom-liquid,\n  .nutrea-marquee-section .section-spacing,\n  .nutrea-marquee-section .section-spacing--tight,\n  .nutrea-marquee-section .section-stack,\n  .nutrea-marquee-section .custom-liquid {\n    margin-top: 0 !important;\n    margin-bottom: 0 !important;\n\n    padding-top: 0 !important;\n    padding-bottom: 0 !important;\n  }\n\n\n  .shopify-section:has(.nutrea-marquee) > div,\n  .nutrea-marquee-section > div {\n    margin-top: 0 !important;\n    margin-bottom: 0 !important;\n\n    padding-top: 0 !important;\n    padding-bottom: 0 !important;\n  }\n\n\n  /* Remove space from the bottom of the section above */\n\n  .nutrea-marquee-previous-section {\n    margin-bottom: 0 !important;\n    padding-bottom: 0 !important;\n  }\n\n\n  .nutrea-marquee-previous-section > *:last-child {\n    margin-bottom: 0 !important;\n    padding-bottom: 0 !important;\n  }\n\n\n\n  /* =====================================================\n     SCROLLING BAR\n  ===================================================== */\n\n\n  .nutrea-marquee {\n    display: block;\n\n   width: 100vw;\nmax-width: none;\nmargin-left: calc(50% - 50vw);\nmargin-right: calc(50% - 50vw);\n\n    overflow: hidden;\n\n    margin-top: 0 !important;\n    margin-bottom: 0 !important;\n\n    padding-top: {{ desktop_padding }}px;\n    padding-bottom: {{ desktop_padding }}px;\n\n    background: {{ bar_background }};\n    color: {{ text_color }};\n  }\n\n\n  .nutrea-marquee__track {\n    display: flex;\n    align-items: center;\n\n    width: max-content;\n\n    animation-name: nutrea-marquee-scroll;\n    animation-duration: {{ scroll_speed }}s;\n    animation-timing-function: linear;\n    animation-iteration-count: infinite;\n\n    will-change: transform;\n  }\n\n\n  .nutrea-marquee__track--reverse {\n    animation-direction: reverse;\n  }\n\n\n  {% if pause_on_hover %}\n\n    .nutrea-marquee__track:hover {\n      animation-play-state: paused;\n    }\n\n  {% endif %}\n\n\n  .nutrea-marquee__group {\n    display: flex;\n    align-items: center;\n\n    flex-shrink: 0;\n\n    gap: {{ item_spacing }}px;\n\n    padding-right: {{ item_spacing }}px;\n  }\n\n\n  .nutrea-marquee__item {\n    display: block;\n\n    flex-shrink: 0;\n\n    white-space: nowrap;\n\n    font-family: inherit;\n\n    font-size: {{ desktop_font_size }}px;\n    font-weight: {{ font_weight }};\n\n    line-height: 1.2;\n\n    letter-spacing: {{ letter_spacing }}px;\n\n    text-transform: {{ text_transform }};\n  }\n\n\n  .nutrea-marquee__separator {\n    display: block;\n\n    flex-shrink: 0;\n\n    font-size: {{ desktop_font_size }}px;\n\n    opacity: {{ separator_opacity }};\n  }\n\n\n\n  /* =====================================================\n     ANIMATION\n  ===================================================== */\n\n\n  @keyframes nutrea-marquee-scroll {\n\n    from {\n      transform: translate3d(0, 0, 0);\n    }\n\n    to {\n      transform: translate3d(-50%, 0, 0);\n    }\n\n  }\n\n\n\n  /* =====================================================\n     MOBILE\n  ===================================================== */\n\n\n  @media screen and (max-width: 749px) {\n\n    .nutrea-marquee {\n      padding-top: {{ mobile_padding }}px;\n      padding-bottom: {{ mobile_padding }}px;\n    }\n\n\n    .nutrea-marquee__item {\n      font-size: {{ mobile_font_size }}px;\n    }\n\n\n    .nutrea-marquee__separator {\n      font-size: {{ mobile_font_size }}px;\n    }\n\n  }\n\n\n\n  /* =====================================================\n     ACCESSIBILITY\n  ===================================================== */\n\n\n  @media (prefers-reduced-motion: reduce) {\n\n    .nutrea-marquee__track {\n      animation: none;\n    }\n\n  }\n\n</style>\n\n\n\n<script>\n\n  (function () {\n\n    var script = document.currentScript;\n\n    if (!script) return;\n\n\n    var currentSection = script.closest('.shopify-section');\n\n\n    if (currentSection) {\n\n      currentSection.classList.add(\n        'nutrea-marquee-section'\n      );\n\n\n      var previousElement =\n        currentSection.previousElementSibling;\n\n\n      while (\n        previousElement &&\n        !previousElement.classList.contains('shopify-section')\n      ) {\n\n        previousElement =\n          previousElement.previousElementSibling;\n\n      }\n\n\n      if (previousElement) {\n\n        previousElement.classList.add(\n          'nutrea-marquee-previous-section'\n        );\n\n      }\n\n    }\n\n  })();\n\n</script>",
