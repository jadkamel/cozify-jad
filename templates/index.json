        "custom_liquid": "{% comment %}\n=====================================================\nNUTREA TRUST BAR\nFULL CUSTOM LIQUID VERSION\n\nREMOVES:\n- GAP ABOVE THE TRUST BAR\n- GAP BELOW THE TRUST BAR\n=====================================================\n{% endcomment %}\n\n\n{% comment %}\n=====================================================\nEDIT COLORS HERE\n=====================================================\n{% endcomment %}\n\n{% assign icon_color = '#B08968' %}\n{% assign text_color = '#1F1F1F' %}\n{% assign divider_color = '#E7DDD4' %}\n{% assign background_color = '#FFFDFC' %}\n\n\n\n<div class=\"nutrea-trust-bar\">\n\n  <div class=\"nutrea-trust-bar__inner\">\n\n\n    {% comment %}\n    =====================================================\n    ITEM 1\n    #1 PREMIUM COLLAGEN\n    =====================================================\n    {% endcomment %}\n\n    <div class=\"nutrea-trust-bar__item\">\n\n      <div class=\"nutrea-trust-bar__icon\">\n\n        <svg\n          viewBox=\"0 0 64 64\"\n          fill=\"none\"\n          xmlns=\"http://www.w3.org/2000/svg\"\n          aria-hidden=\"true\"\n        >\n\n          <path\n            d=\"M20 14H44V25C44 34 39 40 32 43C25 40 20 34 20 25V14Z\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linejoin=\"round\"\n          />\n\n          <path\n            d=\"M20 18H13V23C13 29 17 33 23 34\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n          />\n\n          <path\n            d=\"M44 18H51V23C51 29 47 33 41 34\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n          />\n\n          <path\n            d=\"M32 43V50\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n          />\n\n          <path\n            d=\"M24 54H40\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n          />\n\n          <circle\n            cx=\"32\"\n            cy=\"27\"\n            r=\"8\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n          />\n\n          <path\n            d=\"M29 24H32V32\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n            stroke-linejoin=\"round\"\n          />\n\n        </svg>\n\n      </div>\n\n\n      <div class=\"nutrea-trust-bar__text\">\n\n        <span>#1 PREMIUM COLLAGEN</span>\n\n        <span>IN THE MIDDLE EAST</span>\n\n      </div>\n\n    </div>\n\n\n\n    {% comment %}\n    =====================================================\n    ITEM 2\n    HALAL CERTIFIED\n    =====================================================\n    {% endcomment %}\n\n    <div class=\"nutrea-trust-bar__item\">\n\n      <div class=\"nutrea-trust-bar__icon\">\n\n        <svg\n          viewBox=\"0 0 64 64\"\n          fill=\"none\"\n          xmlns=\"http://www.w3.org/2000/svg\"\n          aria-hidden=\"true\"\n        >\n\n          <circle\n            cx=\"32\"\n            cy=\"32\"\n            r=\"23\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n          />\n\n          <path\n            d=\"M37 20C29 21 24 27 24 34C24 41 29 46 36 46C31 43 29 38 29 33C29 28 32 23 37 20Z\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linejoin=\"round\"\n          />\n\n          <path\n            d=\"M41 25L42.5 28.5L46 30L42.5 31.5L41 35L39.5 31.5L36 30L39.5 28.5L41 25Z\"\n            fill=\"currentColor\"\n          />\n\n        </svg>\n\n      </div>\n\n\n      <div class=\"nutrea-trust-bar__text\">\n\n        <span>HALAL</span>\n\n        <span>CERTIFIED</span>\n\n      </div>\n\n    </div>\n\n\n\n    {% comment %}\n    =====================================================\n    ITEM 3\n    GUARANTEED RESULTS\n    =====================================================\n    {% endcomment %}\n\n    <div class=\"nutrea-trust-bar__item\">\n\n      <div class=\"nutrea-trust-bar__icon\">\n\n        <svg\n          viewBox=\"0 0 64 64\"\n          fill=\"none\"\n          xmlns=\"http://www.w3.org/2000/svg\"\n          aria-hidden=\"true\"\n        >\n\n          <path\n            d=\"M32 9L50 16V29C50 41 43 50 32 55C21 50 14 41 14 29V16L32 9Z\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linejoin=\"round\"\n          />\n\n          <path\n            d=\"M23 32L29 38L42 24\"\n            stroke=\"currentColor\"\n            stroke-width=\"3\"\n            stroke-linecap=\"round\"\n            stroke-linejoin=\"round\"\n          />\n\n        </svg>\n\n      </div>\n\n\n      <div class=\"nutrea-trust-bar__text\">\n\n        <span>GUARANTEED</span>\n\n        <span>RESULTS</span>\n\n      </div>\n\n    </div>\n\n\n\n    {% comment %}\n    =====================================================\n    ITEM 4\n    CLEAN INGREDIENTS\n    =====================================================\n    {% endcomment %}\n\n    <div class=\"nutrea-trust-bar__item\">\n\n      <div class=\"nutrea-trust-bar__icon\">\n\n        <svg\n          viewBox=\"0 0 64 64\"\n          fill=\"none\"\n          xmlns=\"http://www.w3.org/2000/svg\"\n          aria-hidden=\"true\"\n        >\n\n          <path\n            d=\"M49 13C35 15 23 22 18 34C14 44 19 51 27 51C41 51 49 34 49 13Z\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linejoin=\"round\"\n          />\n\n          <path\n            d=\"M18 51C23 39 31 30 43 21\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n          />\n\n        </svg>\n\n      </div>\n\n\n      <div class=\"nutrea-trust-bar__text\">\n\n        <span>CLEAN</span>\n\n        <span>INGREDIENTS</span>\n\n      </div>\n\n    </div>\n\n\n  </div>\n\n</div>\n\n\n\n<style>\n\n  /* =====================================================\n     REMOVE SHOPIFY GAP ABOVE AND BELOW\n  ===================================================== */\n\n\n  .nutrea-trust-section,\n  .nutrea-before-trust-section,\n  .nutrea-after-trust-section {\n\n    margin-top: 2px !important;\n    margin-bottom: 0 !important;\n\n    padding-top: 0 !important;\n    padding-bottom: 0 !important;\n\n    --section-vertical-spacing: 0px !important;\n\n    --section-spacing-block-start: 0px !important;\n\n    --section-spacing-block-end: 0px !important;\n\n    --section-outer-spacing-block: 0px !important;\n\n  }\n\n\n\n  /* =====================================================\n     REMOVE OUTER WRAPPER SPACING\n  ===================================================== */\n\n\n  .nutrea-trust-section > div,\n  .nutrea-before-trust-section > div,\n  .nutrea-after-trust-section > div {\n\n    margin-top: 0 !important;\n    margin-bottom: 0 !important;\n\n    padding-top: 0 !important;\n    padding-bottom: 0 !important;\n\n  }\n\n\n\n  /* =====================================================\n     REMOVE COMMON SHOPIFY SPACING CLASSES\n  ===================================================== */\n\n\n  .nutrea-trust-section .section-spacing,\n  .nutrea-trust-section .section-spacing--tight,\n  .nutrea-trust-section .section-stack,\n  .nutrea-trust-section .custom-liquid,\n  .nutrea-trust-section .prose,\n\n\n  .nutrea-before-trust-section .section-spacing,\n  .nutrea-before-trust-section .section-spacing--tight,\n  .nutrea-before-trust-section .section-stack,\n  .nutrea-before-trust-section .custom-liquid,\n\n\n  .nutrea-after-trust-section .section-spacing,\n  .nutrea-after-trust-section .section-spacing--tight,\n  .nutrea-after-trust-section .section-stack,\n  .nutrea-after-trust-section .custom-liquid {\n\n    margin-top: 0 !important;\n    margin-bottom: 0 !important;\n\n    padding-top: 0 !important;\n    padding-bottom: 0 !important;\n\n  }\n\n\n\n  /* =====================================================\n     REMOVE BOTTOM SPACE FROM SCROLLING BAR SECTION\n  ===================================================== */\n\n\n  .nutrea-before-trust-section {\n\n    margin-bottom: 0 !important;\n\n    padding-bottom: 0 !important;\n\n  }\n\n\n  .nutrea-before-trust-section > *:last-child {\n\n    margin-bottom: 0 !important;\n\n    padding-bottom: 0 !important;\n\n  }\n\n\n\n  /* =====================================================\n     REMOVE TOP SPACE FROM SECTION AFTER TRUST BAR\n  ===================================================== */\n\n\n  .nutrea-after-trust-section {\n\n    margin-top: 1px !important;\n\n    padding-top: 0 !important;\n\n  }\n\n\n  .nutrea-after-trust-section > *:first-child {\n\n    margin-top: 0 !important;\n\n    padding-top: 0 !important;\n\n  }\n\n\n\n  /* =====================================================\n     TRUST BAR\n  ===================================================== */\n\n\n  .nutrea-trust-bar {\n\n    display: block;\n\n    width: 100%;\n\n    max-width: none;\n\n    margin-top: -1px !important;\n\n    margin-bottom: -1px !important;\n\n    padding: 0 !important;\n\n    background: {{ background_color }};\n\n    border-top: 0 !important;\n\n    border-bottom:\n      1px solid {{ divider_color }};\n\n    overflow: hidden;\n\n  }\n\n\n\n  /* =====================================================\n     TRUST BAR INNER CONTAINER\n  ===================================================== */\n\n\n  .nutrea-trust-bar__inner {\n\n    display: grid;\n\n    grid-template-columns:\n      repeat(4, minmax(0, 1fr));\n\n    width: 100%;\n\n    max-width: 1400px;\n\n    margin: 0 auto;\n\n    padding: 0;\n\n  }\n\n\n\n  /* =====================================================\n     EACH TRUST ITEM\n  ===================================================== */\n\n\n  .nutrea-trust-bar__item {\n\n    position: relative;\n\n    display: flex;\n\n    flex-direction: column;\n\n    align-items: center;\n\n    justify-content: center;\n\n    min-height: 145px;\n\n    padding:\n      24px\n      18px;\n\n    text-align: center;\n\n  }\n\n\n\n  /* =====================================================\n     VERTICAL DIVIDERS\n  ===================================================== */\n\n\n  .nutrea-trust-bar__item:not(:last-child)::after {\n\n    content: \"\";\n\n    position: absolute;\n\n    top: 25%;\n\n    right: 0;\n\n    width: 1px;\n\n    height: 50%;\n\n    background: {{ divider_color }};\n\n  }\n\n\n\n  /* =====================================================\n     ICONS\n  ===================================================== */\n\n\n  .nutrea-trust-bar__icon {\n\n    width: 56px;\n\n    height: 56px;\n\n    margin-bottom: 10px;\n\n    color: {{ icon_color }};\n\n  }\n\n\n  .nutrea-trust-bar__icon svg {\n\n    display: block;\n\n    width: 100%;\n\n    height: 100%;\n\n  }\n\n\n\n  /* =====================================================\n     TEXT\n  ===================================================== */\n\n\n  .nutrea-trust-bar__text {\n\n    display: flex;\n\n    flex-direction: column;\n\n    gap: 2px;\n\n    color: {{ text_color }};\n\n    font-family: inherit;\n\n    font-size: 14px;\n\n    font-weight: 600;\n\n    line-height: 1.25;\n\n    letter-spacing: 0.4px;\n\n    text-transform: uppercase;\n\n  }\n\n\n\n  /* =====================================================\n     MOBILE\n  ===================================================== */\n\n\n  @media screen and (max-width: 749px) {\n\n\n    .nutrea-trust-bar__inner {\n\n      grid-template-columns:\n        repeat(4, minmax(0, 1fr));\n\n    }\n\n\n    .nutrea-trust-bar__item {\n\n      min-height: 104px;\n\n      padding:\n        14px\n        5px;\n\n    }\n\n\n    .nutrea-trust-bar__icon {\n\n      width: 38px;\n\n      height: 38px;\n\n      margin-bottom: 7px;\n\n    }\n\n\n    .nutrea-trust-bar__text {\n\n      font-size: 8px;\n\n      line-height: 1.2;\n\n      letter-spacing: 0;\n\n    }\n\n\n    .nutrea-trust-bar__item:not(:last-child)::after {\n\n      top: 20%;\n\n      height: 60%;\n\n    }\n\n  }\n\n</style>\n\n\n\n<script>\n\n  (function () {\n\n    var script = document.currentScript;\n\n    if (!script) return;\n\n\n    var currentSection =\n      script.closest('.shopify-section');\n\n\n    if (!currentSection) return;\n\n\n\n    function removeNutreaTrustGaps() {\n\n\n      /* ================================\n         CURRENT TRUST BAR SECTION\n      ================================ */\n\n      currentSection.classList.add(\n        'nutrea-trust-section'\n      );\n\n\n\n      /* ================================\n         SECTION ABOVE\n      ================================ */\n\n      var previousSection =\n        currentSection.previousElementSibling;\n\n\n      while (\n        previousSection &&\n        !previousSection.classList.contains(\n          'shopify-section'\n        )\n      ) {\n\n        previousSection =\n          previousSection.previousElementSibling;\n\n      }\n\n\n      if (previousSection) {\n\n        previousSection.classList.add(\n          'nutrea-before-trust-section'\n        );\n\n      }\n\n\n\n      /* ================================\n         SECTION BELOW\n      ================================ */\n\n      var nextSection =\n        currentSection.nextElementSibling;\n\n\n      while (\n        nextSection &&\n        !nextSection.classList.contains(\n          'shopify-section'\n        )\n      ) {\n\n        nextSection =\n          nextSection.nextElementSibling;\n\n      }\n\n\n      if (nextSection) {\n\n        nextSection.classList.add(\n          'nutrea-after-trust-section'\n        );\n\n      }\n\n    }\n\n\n\n    if (\n      document.readyState === 'loading'\n    ) {\n\n      document.addEventListener(\n        'DOMContentLoaded',\n        removeNutreaTrustGaps\n      );\n\n    } else {\n\n      removeNutreaTrustGaps();\n\n    }\n\n\n\n    document.addEventListener(\n      'shopify:section:load',\n      removeNutreaTrustGaps\n    );\n\n\n  })();\n\n</script>\n<style>\n  /* =====================================================\n     FINAL FIX — REMOVE THE LARGE GAP UNDER TRUST BAR\n  ===================================================== */\n\n  .shopify-section:has(.nutrea-trust-bar) {\n    margin-bottom: 0 !important;\n    padding-bottom: 0 !important;\n    --section-outer-spacing-block: 0px !important;\n    --section-vertical-spacing: 0px !important;\n  }\n\n  .shopify-section:has(.nutrea-trust-bar)\n  + .shopify-section {\n    margin-top: 0 !important;\n    padding-top: 10px !important;\n\n    --section-outer-spacing-block: 0px !important;\n    --section-vertical-spacing: 0px !important;\n    --section-spacing-block-start: 0px !important;\n  }\n\n  .shopify-section:has(.nutrea-trust-bar)\n  + .shopify-section\n  > * {\n    margin-top: 0 !important;\n    padding-top: 0 !important;\n  }\n\n  .shopify-section:has(.nutrea-trust-bar)\n  + .shopify-section\n  .section-spacing {\n    margin-top: 0 !important;\n    padding-top: 0 !important;\n\n    --section-outer-spacing-block: 0px !important;\n    --section-vertical-spacing: 0px !important;\n  }\n\n  .shopify-section:has(.nutrea-trust-bar)\n  + .shopify-section\n  .container,\n  .shopify-section:has(.nutrea-trust-bar)\n  + .shopify-section\n  .section-stack {\n    margin-top: 0 !important;\n    padding-top: 0 !important;\n  }\n</style>",
