    stroke-linecap=\"round\"\n            stroke-linejoin=\"round\"\n          />\n\n        </svg>\n\n      </div>\n\n      <div class=\"nutrea-trust-bar__text\">\n        <span>#1 PREMIUM COLLAGEN</span>\n        <span>IN THE MIDDLE EAST</span>\n      </div>\n\n    </div>\n\n\n\n    <!-- ITEM 2 -->\n    <div class=\"nutrea-trust-bar__item\">\n\n      <div class=\"nutrea-trust-bar__icon\">\n\n        <svg\n          viewBox=\"0 0 64 64\"\n          fill=\"none\"\n          xmlns=\"http://www.w3.org/2000/svg\"\n          aria-hidden=\"true\"\n        >\n\n          <circle\n            cx=\"32\"\n            cy=\"32\"\n            r=\"23\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n          />\n\n          <path\n            d=\"M37 20C29 21 24 27 24 34C24 41 29 46 36 46C31 43 29 38 29 33C29 28 32 23 37 20Z\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linejoin=\"round\"\n          />\n\n          <path\n            d=\"M41 25L42.5 28.5L46 30L42.5 31.5L41 35L39.5 31.5L36 30L39.5 28.5L41 25Z\"\n            fill=\"currentColor\"\n          />\n\n        </svg>\n\n      </div>\n\n      <div class=\"nutrea-trust-bar__text\">\n        <span>HALAL</span>\n        <span>CERTIFIED</span>\n      </div>\n\n    </div>\n\n\n\n    <!-- ITEM 3 -->\n    <div class=\"nutrea-trust-bar__item\">\n\n      <div class=\"nutrea-trust-bar__icon\">\n\n        <svg\n          viewBox=\"0 0 64 64\"\n          fill=\"none\"\n          xmlns=\"http://www.w3.org/2000/svg\"\n          aria-hidden=\"true\"\n        >\n\n          <path\n            d=\"M32 9L50 16V29C50 41 43 50 32 55C21 50 14 41 14 29V16L32 9Z\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linejoin=\"round\"\n          />\n\n          <path\n            d=\"M23 32L29 38L42 24\"\n            stroke=\"currentColor\"\n            stroke-width=\"3\"\n            stroke-linecap=\"round\"\n            stroke-linejoin=\"r