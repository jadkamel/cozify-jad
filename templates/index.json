    "custom_liquid_p7jExL": {
      "type": "custom-liquid",
      "name": "t:sections.refactor_words.custom_code.name",
      "settings": {
        "heading": "",
        "subheading": "",
        "section_heading_layout": "section-heading--left",
        "custom_liquid": "{% comment %}\n=========================================================\nNUTREA — THE BLEND\nFULLY EDITABLE CUSTOM LIQUID\n\nEDIT ONLY THE SETTINGS BELOW.\nEVERYTHING ELSE CAN STAY AS IT IS.\n=========================================================\n{% endcomment %}\n\n\n\n{% comment %}\n=========================================================\n01 — TEXT CONTENT\n=========================================================\n{% endcomment %}\n\n{% assign blend_eyebrow = 'THE BLEND' %}\n\n{% assign blend_heading = 'Three essentials. One daily ritual.' %}\n\n\n\n{% assign collagen_title = 'COLLAGEN' %}\n\n{% assign collagen_text = 'Premium bovine collagen to support skin elasticity, strengthen hair and nails, and support everyday vitality.' %}\n\n\n\n{% assign electrolytes_title = 'ELECTROLYTES' %}\n\n{% assign electrolytes_text = 'Essential minerals to support hydration, muscle function, and overall balance throughout the day.' %}\n\n\n\n{% assign vitamin_c_title = 'VITAMIN C' %}\n\n{% assign vitamin_c_text = 'A powerful antioxidant that supports collagen production and immune health.' %}\n\n\n\n\n\n{% comment %}\n=========================================================\n02 — COLORS\n=========================================================\n{% endcomment %}\n\n{% assign blend_background = '#FFFDFC' %}\n\n{% assign blend_heading_color = '#2B211C' %}\n\n{% assign blend_title_color = '#2B211C' %}\n\n{% assign blend_text_color = '#66564C' %}\n\n{% assign blend_accent_color = '#B08968' %}\n\n{% assign blend_divider_color = '#E7DDD4' %}\n\n\n\n\n\n{% comment %}\n=========================================================\n03 — DESKTOP TYPOGRAPHY\n=========================================================\n{% endcomment %}\n\n{% assign desktop_eyebrow_size = 10 %}\n\n{% assign desktop_heading_size = 34 %}\n\n{% assign desktop_ingredient_title_size = 13 %}\n\n{% assign desktop_body_size = 13 %}\n\n\n\n{% comment %}\nFONT WEIGHTS\n\n300 = light\n400 = regular\n500 = medium\n600 = semi-bold\n700 = bold\n=========================================================\n{% endcomment %}\n\n{% assign eyebrow_weight = 700 %}\n\n{% assign heading_weight = 500 %}\n\n{% assign ingredient_title_weight = 600 %}\n\n{% assign body_weight = 400 %}\n\n\n\n\n\n{% comment %}\n=========================================================\n04 — MOBILE TYPOGRAPHY\n=========================================================\n{% endcomment %}\n\n{% assign mobile_eyebrow_size = 15 %}\n\n{% assign mobile_heading_size = 20 %}\n\n{% assign mobile_ingredient_title_size = 12 %}\n\n{% assign mobile_body_size = 12 %}\n\n\n\n\n\n{% comment %}\n=========================================================\n05 — LETTER SPACING\n\nUse values such as:\n\n0px\n0.2px\n1px\n1.5px\n2px\n=========================================================\n{% endcomment %}\n\n{% assign eyebrow_letter_spacing = '1.8px' %}\n\n{% assign heading_letter_spacing = '-0.5px' %}\n\n{% assign ingredient_title_letter_spacing = '1px' %}\n\n{% assign body_letter_spacing = '0px' %}\n\n\n\n\n\n{% comment %}\n=========================================================\n06 — SECTION SIZE AND SPACING\n=========================================================\n{% endcomment %}\n\n{% assign section_max_width = 1100 %}\n\n\n\n{% assign desktop_padding_top = 48 %}\n\n{% assign desktop_padding_bottom = 48 %}\n\n{% assign desktop_padding_sides = 20 %}\n\n\n\n{% assign mobile_padding_top = 34 %}\n\n{% assign mobile_padding_bottom = 34 %}\n\n{% assign mobile_padding_sides = 16 %}\n\n\n\n\n\n{% comment %}\n=========================================================\n07 — HEADER SPACING\n=========================================================\n{% endcomment %}\n\n{% assign eyebrow_bottom_gap = 10 %}\n\n{% assign header_bottom_gap = 36 %}\n\n\n\n\n\n{% comment %}\n=========================================================\n08 — COLUMN SPACING\n=========================================================\n{% endcomment %}\n\n{% assign desktop_column_padding = 34 %}\n\n{% assign mobile_item_gap = 26 %}\n\n\n\n\n\n{% comment %}\n=========================================================\n09 — ICON SETTINGS\n=========================================================\n{% endcomment %}\n\n{% assign desktop_icon_size = 44 %}\n\n{% assign mobile_icon_size = 38 %}\n\n\n\n{% assign desktop_icon_bottom_gap = 16 %}\n\n{% assign mobile_icon_bottom_gap = 14 %}\n\n\n\n{% assign icon_line_width = 1.6 %}\n\n\n\n\n\n{% comment %}\n=========================================================\n10 — TEXT WIDTH AND SPACING\n=========================================================\n{% endcomment %}\n\n{% assign ingredient_title_bottom_gap = 9 %}\n\n{% assign ingredient_text_max_width = 270 %}\n\n{% assign body_line_height = 1.5 %}\n\n\n\n\n\n{% comment %}\n=========================================================\n11 — DIVIDERS\n\ntrue = show\nfalse = hide\n=========================================================\n{% endcomment %}\n\n{% assign show_dividers = true %}\n\n{% assign divider_height = 92 %}\n\n\n\n\n\n{% comment %}\n=========================================================\nDO NOT EDIT BELOW UNLESS YOU WANT TO CHANGE THE STRUCTURE\n=========================================================\n{% endcomment %}\n\n\n\n<div\n  id=\"nutrea-blend-{{ section.id }}\"\n  class=\"nutrea-blend\"\n  style=\"\n    --nb-background: {{ blend_background }};\n    --nb-heading: {{ blend_heading_color }};\n    --nb-title: {{ blend_title_color }};\n    --nb-text: {{ blend_text_color }};\n    --nb-accent: {{ blend_accent_color }};\n    --nb-divider: {{ blend_divider_color }};\n\n    --nb-max-width: {{ section_max_width }}px;\n\n    --nb-desktop-padding-top: {{ desktop_padding_top }}px;\n    --nb-desktop-padding-bottom: {{ desktop_padding_bottom }}px;\n    --nb-desktop-padding-sides: {{ desktop_padding_sides }}px;\n\n    --nb-mobile-padding-top: {{ mobile_padding_top }}px;\n    --nb-mobile-padding-bottom: {{ mobile_padding_bottom }}px;\n    --nb-mobile-padding-sides: {{ mobile_padding_sides }}px;\n\n    --nb-desktop-eyebrow-size: {{ desktop_eyebrow_size }}px;\n    --nb-desktop-heading-size: {{ desktop_heading_size }}px;\n    --nb-desktop-title-size: {{ desktop_ingredient_title_size }}px;\n    --nb-desktop-body-size: {{ desktop_body_size }}px;\n\n    --nb-mobile-eyebrow-size: {{ mobile_eyebrow_size }}px;\n    --nb-mobile-heading-size: {{ mobile_heading_size }}px;\n    --nb-mobile-title-size: {{ mobile_ingredient_title_size }}px;\n    --nb-mobile-body-size: {{ mobile_body_size }}px;\n\n    --nb-eyebrow-weight: {{ eyebrow_weight }};\n    --nb-heading-weight: {{ heading_weight }};\n    --nb-title-weight: {{ ingredient_title_weight }};\n    --nb-body-weight: {{ body_weight }};\n\n    --nb-eyebrow-spacing: {{ eyebrow_letter_spacing }};\n    --nb-heading-spacing: {{ heading_letter_spacing }};\n    --nb-title-spacing: {{ ingredient_title_letter_spacing }};\n    --nb-body-spacing: {{ body_letter_spacing }};\n\n    --nb-eyebrow-gap: {{ eyebrow_bottom_gap }}px;\n    --nb-header-gap: {{ header_bottom_gap }}px;\n\n    --nb-column-padding: {{ desktop_column_padding }}px;\n    --nb-mobile-item-gap: {{ mobile_item_gap }}px;\n\n    --nb-desktop-icon-size: {{ desktop_icon_size }}px;\n    --nb-mobile-icon-size: {{ mobile_icon_size }}px;\n    --nb-desktop-icon-gap: {{ desktop_icon_bottom_gap }}px;\n    --nb-mobile-icon-gap: {{ mobile_icon_bottom_gap }}px;\n\n    --nb-icon-line-width: {{ icon_line_width }};\n\n    --nb-title-gap: {{ ingredient_title_bottom_gap }}px;\n    --nb-text-width: {{ ingredient_text_max_width }}px;\n    --nb-body-line-height: {{ body_line_height }};\n\n    --nb-divider-height: {{ divider_height }}px;\n  \"\n>\n\n\n  <div class=\"nutrea-blend__inner\">\n\n\n    {% comment %}\n    =========================================\n    HEADER\n    =========================================\n    {% endcomment %}\n\n    <div class=\"nutrea-blend__header\">\n\n      <span class=\"nutrea-blend__eyebrow\">\n\n        {{ blend_eyebrow }}\n\n      </span>\n\n\n      <h2 class=\"nutrea-blend__heading\">\n\n        {{ blend_heading }}\n\n      </h2>\n\n    </div>\n\n\n\n    {% comment %}\n    =========================================\n    3 INGREDIENTS\n    =========================================\n    {% endcomment %}\n\n    <div class=\"nutrea-blend__grid\">\n\n\n\n      {% comment %}\n      =========================================\n      COLLAGEN\n      =========================================\n      {% endcomment %}\n\n      <div class=\"nutrea-blend__item\">\n\n\n        <div class=\"nutrea-blend__icon\">\n\n          <svg\n            viewBox=\"0 0 48 48\"\n            fill=\"none\"\n            aria-hidden=\"true\"\n          >\n\n            <circle\n              cx=\"24\"\n              cy=\"8\"\n              r=\"3\"\n            />\n\n            <circle\n              cx=\"24\"\n              cy=\"40\"\n              r=\"3\"\n            />\n\n            <circle\n              cx=\"8\"\n              cy=\"24\"\n              r=\"3\"\n            />\n\n            <circle\n              cx=\"40\"\n              cy=\"24\"\n              r=\"3\"\n            />\n\n\n            <circle\n              cx=\"15\"\n              cy=\"15\"\n              r=\"2.5\"\n            />\n\n            <circle\n              cx=\"33\"\n              cy=\"15\"\n              r=\"2.5\"\n            />\n\n            <circle\n              cx=\"15\"\n              cy=\"33\"\n              r=\"2.5\"\n            />\n\n            <circle\n              cx=\"33\"\n              cy=\"33\"\n              r=\"2.5\"\n            />\n\n\n            <path d=\"M24 11V37\" />\n\n            <path d=\"M11 24H37\" />\n\n            <path d=\"M17 17L31 31\" />\n\n            <path d=\"M31 17L17 31\" />\n\n          </svg>\n\n        </div>\n\n\n        <h3 class=\"nutrea-blend__item-title\">\n\n          {{ collagen_title }}\n\n        </h3>\n\n\n        <p class=\"nutrea-blend__item-text\">\n\n          {{ collagen_text }}\n\n        </p>\n\n\n      </div>\n\n\n\n      {% if show_dividers %}\n\n        <span\n          class=\"nutrea-blend__divider\"\n          aria-hidden=\"true\"\n        ></span>\n\n      {% endif %}\n\n\n\n      {% comment %}\n      =========================================\n      ELECTROLYTES\n      =========================================\n      {% endcomment %}\n\n      <div class=\"nutrea-blend__item\">\n\n\n        <div class=\"nutrea-blend__icon\">\n\n          <svg\n            viewBox=\"0 0 48 48\"\n            fill=\"none\"\n            aria-hidden=\"true\"\n          >\n\n            <path\n              d=\"\n                M24 6\n                C24 6 12.5 20 12.5 29\n                C12.5 35.35 17.65 40.5 24 40.5\n                C30.35 40.5 35.5 35.35 35.5 29\n                C35.5 20 24 6 24 6Z\n              \"\n            />\n\n\n            <path\n              d=\"\n                M18.5 30\n                C19.8 33.2 21.9 35 25 35\n              \"\n            />\n\n          </svg>\n\n        </div>\n\n\n        <h3 class=\"nutrea-blend__item-title\">\n\n          {{ electrolytes_title }}\n\n        </h3>\n\n\n        <p class=\"nutrea-blend__item-text\">\n\n          {{ electrolytes_text }}\n\n        </p>\n\n\n      </div>\n\n\n\n      {% if show_dividers %}\n\n        <span\n          class=\"nutrea-blend__divider\"\n          aria-hidden=\"true\"\n        ></span>\n\n      {% endif %}\n\n\n\n      {% comment %}\n      =========================================\n      VITAMIN C\n      =========================================\n      {% endcomment %}\n\n      <div class=\"nutrea-blend__item\">\n\n\n        <div class=\"nutrea-blend__icon\">\n\n          <svg\n            viewBox=\"0 0 48 48\"\n            fill=\"none\"\n            aria-hidden=\"true\"\n          >\n\n            <circle\n              cx=\"24\"\n              cy=\"24\"\n              r=\"15\"\n            />\n\n\n            <path\n              d=\"\n                M24 9\n                C24 15 24 33 24 39\n              \"\n            />\n\n\n            <path\n              d=\"\n                M11 17\n                C16 19 20 21 24 24\n                C28 27 32 29 37 31\n              \"\n            />\n\n\n            <path\n              d=\"\n                M11 31\n                C16 29 20 27 24 24\n                C28 21 32 19 37 17\n              \"\n            />\n\n\n            <path\n              d=\"\n                M18 6\n                C21 7 23 8.5 24 11\n                C25.5 8 28 6.5 31 6\n              \"\n            />\n\n          </svg>\n\n        </div>\n\n\n        <h3 class=\"nutrea-blend__item-title\">\n\n          {{ vitamin_c_title }}\n\n        </h3>\n\n\n        <p class=\"nutrea-blend__item-text\">\n\n          {{ vitamin_c_text }}\n\n        </p>\n\n\n      </div>\n\n\n    </div>\n\n  </div>\n\n</div>\n\n\n\n<style>\n\n  /* =====================================================\n     SECTION\n  ===================================================== */\n\n  #nutrea-blend-{{ section.id }} {\n    width: 100%;\n\n    box-sizing: border-box;\n\n    background:\n      var(--nb-background);\n\n    padding:\n      var(--nb-desktop-padding-top)\n      var(--nb-desktop-padding-sides)\n      var(--nb-desktop-padding-bottom);\n\n    color:\n      var(--nb-heading);\n  }\n\n\n\n  #nutrea-blend-{{ section.id }} * {\n    box-sizing: border-box;\n  }\n\n\n\n  /* =====================================================\n     INNER CONTAINER\n  ===================================================== */\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__inner {\n\n    width: 100%;\n\n    max-width:\n      var(--nb-max-width);\n\n    margin:\n      0 auto;\n\n  }\n\n\n\n  /* =====================================================\n     HEADER\n  ===================================================== */\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__header {\n\n    margin-bottom:\n      var(--nb-header-gap);\n\n    text-align:\n      center;\n\n  }\n\n\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__eyebrow {\n\n    display:\n      block;\n\n    margin-bottom:\n      var(--nb-eyebrow-gap);\n\n    color:\n      var(--nb-accent);\n\n    font-size:\n      var(--nb-desktop-eyebrow-size);\n\n    font-weight:\n      var(--nb-eyebrow-weight);\n\n    line-height:\n      1;\n\n    letter-spacing:\n      var(--nb-eyebrow-spacing);\n\n    text-transform:\n      uppercase;\n\n  }\n\n\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__heading {\n\n    margin:\n      0;\n\n    color:\n      var(--nb-heading);\n\n    font-size:\n      var(--nb-desktop-heading-size);\n\n    font-weight:\n      var(--nb-heading-weight);\n\n    line-height:\n      1.12;\n\n    letter-spacing:\n      var(--nb-heading-spacing);\n\n  }\n\n\n\n  /* =====================================================\n     GRID\n  ===================================================== */\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__grid {\n\n    display:\n      grid;\n\n    grid-template-columns:\n      minmax(0, 1fr)\n      auto\n      minmax(0, 1fr)\n      auto\n      minmax(0, 1fr);\n\n    align-items:\n      center;\n\n    width:\n      100%;\n\n  }\n\n\n\n  /* =====================================================\n     EACH INGREDIENT\n  ===================================================== */\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__item {\n\n    min-width:\n      0;\n\n    padding:\n      0\n      var(--nb-column-padding);\n\n    text-align:\n      center;\n\n  }\n\n\n\n  /* =====================================================\n     ICONS\n  ===================================================== */\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__icon {\n\n    width:\n      var(--nb-desktop-icon-size);\n\n    height:\n      var(--nb-desktop-icon-size);\n\n    margin:\n      0 auto\n      var(--nb-desktop-icon-gap);\n\n    color:\n      var(--nb-accent);\n\n  }\n\n\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__icon svg {\n\n    display:\n      block;\n\n    width:\n      100%;\n\n    height:\n      100%;\n\n  }\n\n\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__icon svg * {\n\n    stroke:\n      currentColor;\n\n    stroke-width:\n      var(--nb-icon-line-width);\n\n    stroke-linecap:\n      round;\n\n    stroke-linejoin:\n      round;\n\n    vector-effect:\n      non-scaling-stroke;\n\n  }\n\n\n\n  /* =====================================================\n     INGREDIENT TITLES\n  ===================================================== */\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__item-title {\n\n    margin:\n      0\n      0\n      var(--nb-title-gap);\n\n    color:\n      var(--nb-title);\n\n    font-size:\n      var(--nb-desktop-title-size);\n\n    font-weight:\n      var(--nb-title-weight);\n\n    line-height:\n      1.15;\n\n    letter-spacing:\n      var(--nb-title-spacing);\n\n    text-transform:\n      uppercase;\n\n  }\n\n\n\n  /* =====================================================\n     BODY TEXT\n  ===================================================== */\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__item-text {\n\n    width:\n      100%;\n\n    max-width:\n      var(--nb-text-width);\n\n    margin:\n      0 auto;\n\n    color:\n      var(--nb-text);\n\n    font-size:\n      var(--nb-desktop-body-size);\n\n    font-weight:\n      var(--nb-body-weight);\n\n    line-height:\n      var(--nb-body-line-height);\n\n    letter-spacing:\n      var(--nb-body-spacing);\n\n  }\n\n\n\n  /* =====================================================\n     DIVIDERS\n  ===================================================== */\n\n  #nutrea-blend-{{ section.id }}\n  .nutrea-blend__divider {\n\n    display:\n      block;\n\n    width:\n      1px;\n\n    height:\n      var(--nb-divider-height);\n\n    background:\n      var(--nb-divider);\n\n  }\n\n\n\n  /* ======